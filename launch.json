{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: uvicorn reload",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--port", "8000"],
      "cwd": "${workspaceFolder}/src/backend/python",
      "envFile": "${workspaceFolder}/src/backend/python/.env",
      "jinja": true
    }
  ]
}