ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-3-haiku-20240307
DATABASE_URL=mssql+pyodbc://username:password@server.database.windows.net/antbarter?driver=ODBC+Driver+18+for+SQL+Server

# Usage guardrails (tune for your deployment)
AI_MAX_REQUESTS_PER_DAY=20
AI_MAX_REQUESTS_PER_MONTH=200
AI_MAX_OUTPUT_TOKENS=350
AI_MAX_INPUT_CHARS=4000
AI_MONTHLY_TOKEN_BUDGET=60000

# Content safety (leave True in production)
# When True, input is classified for prohibited categories BEFORE Claude is called,
# and Claude's output is scrubbed for PII (emails, phone numbers, street addresses)
# BEFORE being stored or returned. Set to false ONLY for local development.
SAFETY_MODERATION_ENABLED=true
# Optional comma-separated extra terms to block (case-insensitive substring match)
# SAFETY_EXTRA_BLOCKLIST=

# CORS: comma-separated origins for production (leave empty for dev wildcard — not for production)
# CORS_ALLOW_ORIGINS=https://your-app.example.com
# CORS_ALLOW_CREDENTIALS=false

# Optional default jurisdiction for agreement drafts when the client omits it
# DEFAULT_AGREEMENT_JURISDICTION=

# --- Stripe subscription billing ---
# All three secrets are loaded from this env file ONLY. Never commit real
# values; never paste them into HTML/JS. Use sk_test_... for the Stripe test
# mode and sk_live_... only once you're live and have SSL.
# STRIPE_SECRET_KEY=sk_test_replace_me
# STRIPE_PRICE_ID=price_replace_me
# STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Public-facing URLs Stripe redirects to after checkout. Must be HTTPS in
# live mode. Leave blank to use the request's Origin header.
# STRIPE_SUCCESS_URL=https://yourdomain.com/?subscribed=1
# STRIPE_CANCEL_URL=https://yourdomain.com/?subscribed=0
# Flip to true once Stripe is verified end-to-end. Until then, the chat
# endpoint stays open so you don't lock yourself out during setup.
# BILLING_ENFORCED=false

# Meta Content Library — Facebook Marketplace listing preview (approved access only; server-side only)
# Guide: https://developers.facebook.com/docs/content-library-and-api/content-library-api/guides/fb-marketplace/
# META_CONTENT_LIBRARY_ENABLED=false
# META_MARKETPLACE_MAX_QUERY_LEN=200
# META_CONTENT_LIBRARY_HTTP_BASE_URL=
# META_CONTENT_LIBRARY_ACCESS_TOKEN=
