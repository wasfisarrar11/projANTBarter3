CLAUDE_MODEL=claude-3-haiku-20240307
DATABASE_URL=mssql+pyodbc://username:password@server.database.windows.net/antbarter?driver=ODBC+Driver+18+for+SQL+Server

# Usage guardrails (tune for your deployment)
AI_MAX_REQUESTS_PER_DAY=20
AI_MAX_REQUESTS_PER_MONTH=200
AI_MAX_OUTPUT_TOKENS=350
AI_MAX_INPUT_CHARS=4000
AI_MONTHLY_TOKEN_BUDGET=60000

# CORS: comma-separated origins for production (leave empty for dev wildcard — not for production)
# CORS_ALLOW_ORIGINS=https://your-app.example.com
# CORS_ALLOW_CREDENTIALS=false

# Optional default jurisdiction for agreement drafts when the client omits it
# DEFAULT_AGREEMENT_JURISDICTION=

# Meta Content Library — Facebook Marketplace listing preview (approved access only; server-side only)
# Guide: https://developers.facebook.com/docs/content-library-and-api/content-library-api/guides/fb-marketplace/
# META_CONTENT_LIBRARY_ENABLED=false
# META_MARKETPLACE_MAX_QUERY_LEN=200
# META_CONTENT_LIBRARY_HTTP_BASE_URL=
# META_CONTENT_LIBRARY_ACCESS_TOKEN=
